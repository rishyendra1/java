class MyHashSet {

    boolean[] set;

    public MyHashSet() {
        set = new boolean[1000001]; // keys from 0 to 10^6
    }

    public void add(int key) {
        set[key] = true;
    }

    public void remove(int key) {
        set[key] = false;
    }

    public boolean contains(int key) {
        return set[key];
    }
}



